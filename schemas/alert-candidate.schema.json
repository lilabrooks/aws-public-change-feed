{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aws-alerting:schema:alert-candidate:3",
  "title": "AWS public change alert candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "candidate_id",
    "audience_fingerprint",
    "created_at",
    "announcement",
    "service",
    "risk",
    "route_id",
    "environment_ids",
    "relevance_basis",
    "explainability",
    "recommended_action",
    "release"
  ],
  "properties": {
    "contract_version": {"const": 3},
    "candidate_id": {"$ref": "#/$defs/sha256"},
    "audience_fingerprint": {"$ref": "#/$defs/sha256"},
    "created_at": {"type": "string", "format": "date-time"},
    "announcement": {"$ref": "#/$defs/announcement"},
    "service": {"$ref": "#/$defs/service"},
    "risk": {"$ref": "#/$defs/risk"},
    "route_id": {"$ref": "#/$defs/id"},
    "environment_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "relevance_basis": {"const": "inferred_profile_match"},
    "explainability": {"$ref": "#/$defs/explainability"},
    "recommended_action": {"type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*"},
    "release": {"$ref": "#/$defs/release"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nonempty_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": ".*\\S.*"
    },
    "announcement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "announcement_id",
        "revision_id",
        "content_fingerprint",
        "title",
        "summary",
        "url",
        "observed_at",
        "is_update",
        "provenance"
      ],
      "properties": {
        "source_type": {"const": "public_feed"},
        "announcement_id": {"$ref": "#/$defs/sha256"},
        "revision_id": {"$ref": "#/$defs/sha256"},
        "content_fingerprint": {"$ref": "#/$defs/sha256"},
        "title": {"type": "string", "minLength": 1, "maxLength": 300, "pattern": ".*\\S.*"},
        "summary": {"type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*"},
        "url": {"type": "string", "format": "uri", "pattern": "^https://", "maxLength": 2048},
        "published_at": {"type": "string", "format": "date-time"},
        "observed_at": {"type": "string", "format": "date-time"},
        "is_update": {"type": "boolean"},
        "provenance": {
          "type": "array",
          "minItems": 1,
          "maxItems": 25,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/provenance"}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feed_name", "feed_url", "source_item_id"],
      "properties": {
        "feed_name": {"$ref": "#/$defs/id"},
        "feed_url": {"type": "string", "format": "uri", "pattern": "^https://", "maxLength": 2048},
        "source_item_id": {"type": "string", "minLength": 1, "maxLength": 2048},
        "source_item_url": {"type": "string", "format": "uri", "pattern": "^https://", "maxLength": 2048}
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "display_name"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "display_name": {"$ref": "#/$defs/nonempty_string"}
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "risk_type", "priority"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/id"},
        "risk_type": {"$ref": "#/$defs/id"},
        "priority": {"enum": ["low", "medium", "high"]}
      }
    },
    "explainability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matched_profile_ids", "matched_aliases", "matched_terms", "matched_fields", "reason"],
      "properties": {
        "matched_profile_ids": {"$ref": "#/$defs/ids"},
        "matched_aliases": {"$ref": "#/$defs/strings"},
        "matched_terms": {"$ref": "#/$defs/strings"},
        "matched_fields": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"enum": ["title", "summary"]}
        },
        "reason": {"type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*"}
      }
    },
    "ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "strings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonempty_string"}
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "version_id", "sha256", "schema_version"],
      "properties": {
        "key": {"type": "string", "minLength": 1, "maxLength": 1024},
        "version_id": {"type": "string", "minLength": 1, "maxLength": 1024},
        "sha256": {"$ref": "#/$defs/sha256"},
        "schema_version": {"type": "integer", "minimum": 1}
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_id", "config", "inventory", "application_version"],
      "properties": {
        "release_id": {"$ref": "#/$defs/sha256"},
        "config": {"$ref": "#/$defs/artifact"},
        "inventory": {"$ref": "#/$defs/artifact"},
        "application_version": {"type": "string", "minLength": 1, "maxLength": 100}
      }
    }
  }
}
