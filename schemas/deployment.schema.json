{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aws-alerting:schema:deployment:3",
  "title": "AWS public change alerting deployment configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deployment_id",
    "deployment_region",
    "secret_store",
    "deploy_operational_sns_topic",
    "operational_sns_topic_name",
    "log_retention_days",
    "config_bucket_name",
    "release_prefix",
    "config_filename",
    "inventory_filename",
    "active_versions_object_key",
    "slack",
    "environments",
    "s3_lifecycle",
    "feed_fetch_policy",
    "scale_envelope"
  ],
  "properties": {
    "schema_version": {"const": 3},
    "deployment_id": {"$ref": "#/$defs/id"},
    "deployment_region": {"$ref": "#/$defs/region"},
    "secret_store": {"enum": ["secrets_manager", "ssm_parameter_store"]},
    "deploy_operational_sns_topic": {"const": true},
    "operational_sns_topic_name": {"$ref": "#/$defs/id"},
    "log_retention_days": {"type": "integer", "minimum": 1, "maximum": 3653},
    "config_bucket_name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63,
      "pattern": "^(?!xn--)(?!sthree-)(?!amzn-s3-demo-)(?![0-9]{1,3}(?:\\.[0-9]{1,3}){3}$)(?!.*\\.\\.)(?!.*(?:-s3alias|--ol-s3|\\.mrap|--x-s3|--table-s3|-an)$)[a-z0-9][a-z0-9.-]*[a-z0-9]$"
    },
    "release_prefix": {"$ref": "#/$defs/object_prefix"},
    "config_filename": {"const": "config.yaml"},
    "inventory_filename": {"const": "inventory.json"},
    "active_versions_object_key": {"$ref": "#/$defs/object_key"},
    "slack": {"$ref": "#/$defs/slack"},
    "environments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {"$ref": "#/$defs/environment"}
    },
    "s3_lifecycle": {"$ref": "#/$defs/s3_lifecycle"},
    "feed_fetch_policy": {"$ref": "#/$defs/feed_fetch_policy"},
    "scale_envelope": {"$ref": "#/$defs/scale_envelope"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "region": {
      "type": "string",
      "pattern": "^[a-z]{2}(-gov)?-[a-z]+-[0-9]+$"
    },
    "account_id": {"type": "string", "pattern": "^[0-9]{12}$"},
    "object_key": {"type": "string", "minLength": 1, "maxLength": 1024},
    "object_prefix": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900,
      "pattern": "^(?!/)(?!.*//)(?!.*\\.\\.)(?!.*\\/$).+$"
    },
    "host": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[a-z0-9.-]+$"
    },
    "slack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delivery_mode", "default_route_id", "routes", "rate_control"],
      "properties": {
        "delivery_mode": {"enum": ["incoming_webhook", "bot_token"]},
        "default_route_id": {"$ref": "#/$defs/id"},
        "approved_webhook_hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/host"}
        },
        "workspace_id": {"type": "string", "pattern": "^T[A-Z0-9]+$"},
        "bot_token_secret_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "routes": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 20,
          "propertyNames": {"$ref": "#/$defs/id"},
          "additionalProperties": {"$ref": "#/$defs/slack_route"}
        },
        "rate_control": {"$ref": "#/$defs/slack_rate_control"}
      },
      "allOf": [
        {
          "if": {"properties": {"delivery_mode": {"const": "incoming_webhook"}}, "required": ["delivery_mode"]},
          "then": {
            "required": ["approved_webhook_hosts"],
            "not": {"anyOf": [{"required": ["workspace_id"]}, {"required": ["bot_token_secret_id"]}]}
          }
        },
        {
          "if": {"properties": {"delivery_mode": {"const": "bot_token"}}, "required": ["delivery_mode"]},
          "then": {
            "required": ["workspace_id", "bot_token_secret_id"],
            "not": {"required": ["approved_webhook_hosts"]}
          }
        }
      ]
    },
    "slack_rate_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "per_destination_min_interval_seconds",
        "slack_request_timeout_seconds",
        "max_retry_after_seconds",
        "max_network_attempts",
        "queue_max_receive_count",
        "worker_reserved_concurrency"
      ],
      "properties": {
        "per_destination_min_interval_seconds": {"type": "integer", "minimum": 1, "maximum": 60},
        "slack_request_timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 30},
        "max_retry_after_seconds": {"type": "integer", "minimum": 1, "maximum": 43100},
        "max_network_attempts": {"type": "integer", "minimum": 1, "maximum": 20},
        "queue_max_receive_count": {"type": "integer", "minimum": 10, "maximum": 1000},
        "worker_reserved_concurrency": {"type": "integer", "minimum": 1, "maximum": 20}
      }
    },
    "slack_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_label", "destination_key"],
      "properties": {
        "channel_label": {"type": "string", "minLength": 1, "maxLength": 100},
        "destination_key": {"$ref": "#/$defs/id"},
        "credential_secret_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "channel_id": {"type": "string", "pattern": "^C[A-Z0-9]+$"},
        "high_priority_usergroup_id": {"type": "string", "pattern": "^S[A-Z0-9]+$"}
      },
      "oneOf": [
        {"required": ["credential_secret_id"], "not": {"required": ["channel_id"]}},
        {"required": ["channel_id"], "not": {"required": ["credential_secret_id"]}}
      ]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "customer", "account_id", "regions", "route_id"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "customer": {"type": "string", "minLength": 1, "maxLength": 100, "pattern": ".*\\S.*"},
        "account_id": {"$ref": "#/$defs/account_id"},
        "regions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/region"}
        },
        "route_id": {"$ref": "#/$defs/id"}
      }
    },
    "s3_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_noncurrent_version_expiration_days",
        "retired_release_retention_days",
        "minimum_retained_releases",
        "abort_incomplete_multipart_upload_days",
        "transition_current_versions",
        "raw_feed_snapshots_expiration_days"
      ],
      "properties": {
        "manifest_noncurrent_version_expiration_days": {"type": "integer", "minimum": 30},
        "retired_release_retention_days": {"type": "integer", "minimum": 30, "maximum": 3650},
        "minimum_retained_releases": {"type": "integer", "minimum": 2, "maximum": 100},
        "abort_incomplete_multipart_upload_days": {"type": "integer", "minimum": 1},
        "transition_current_versions": {"const": false},
        "raw_feed_snapshots_expiration_days": {"type": "integer", "minimum": 1, "maximum": 365}
      }
    },
    "feed_fetch_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_feed_hosts",
        "connect_timeout_seconds",
        "response_timeout_seconds",
        "max_redirects",
        "max_response_bytes",
        "max_items_per_feed",
        "max_item_characters",
        "max_concurrent_fetches"
      ],
      "properties": {
        "allowed_feed_hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/host"}
        },
        "connect_timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 30},
        "response_timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 60},
        "max_redirects": {"const": 0},
        "max_response_bytes": {"type": "integer", "minimum": 1024, "maximum": 5242880},
        "max_items_per_feed": {"type": "integer", "minimum": 1, "maximum": 200},
        "max_item_characters": {"type": "integer", "minimum": 1000, "maximum": 50000},
        "max_concurrent_fetches": {"type": "integer", "minimum": 1, "maximum": 5}
      }
    },
    "scale_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_accounts",
        "max_environments",
        "max_feeds",
        "max_slack_routes",
        "max_service_definitions",
        "max_service_profiles",
        "max_risk_rules",
        "max_delivery_requests_per_hour",
        "max_delivery_requests_per_destination_per_hour"
      ],
      "properties": {
        "max_accounts": {"type": "integer", "minimum": 1, "maximum": 100},
        "max_environments": {"type": "integer", "minimum": 1, "maximum": 500},
        "max_feeds": {"type": "integer", "minimum": 1, "maximum": 25},
        "max_slack_routes": {"type": "integer", "minimum": 1, "maximum": 20},
        "max_service_definitions": {"type": "integer", "minimum": 1, "maximum": 100},
        "max_service_profiles": {"type": "integer", "minimum": 1, "maximum": 100},
        "max_risk_rules": {"type": "integer", "minimum": 1, "maximum": 50},
        "max_delivery_requests_per_hour": {"type": "integer", "minimum": 1, "maximum": 1000},
        "max_delivery_requests_per_destination_per_hour": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        }
      }
    }
  }
}
