{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aws-alerting:schema:inventory:3",
  "title": "AWS public change alerting generated inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "deployment_id", "generated_at", "deployment_region", "slack", "environments"],
  "properties": {
    "schema_version": {"const": 3},
    "deployment_id": {"$ref": "#/$defs/id"},
    "generated_at": {"type": "string", "format": "date-time"},
    "deployment_region": {"$ref": "#/$defs/region"},
    "slack": {"$ref": "#/$defs/slack"},
    "environments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {"$ref": "#/$defs/environment"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "region": {"type": "string", "pattern": "^[a-z]{2}(-gov)?-[a-z]+-[0-9]+$"},
    "slack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delivery_mode", "default_route_id", "routes", "rate_control"],
      "properties": {
        "delivery_mode": {"enum": ["incoming_webhook", "bot_token"]},
        "default_route_id": {"$ref": "#/$defs/id"},
        "approved_webhook_hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9.-]+$"}
        },
        "workspace_id": {"type": "string", "pattern": "^T[A-Z0-9]+$"},
        "bot_token_secret_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "routes": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 20,
          "propertyNames": {"$ref": "#/$defs/id"},
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["channel_label", "destination_key"],
            "properties": {
              "channel_label": {"type": "string", "minLength": 1, "maxLength": 100},
              "destination_key": {"$ref": "#/$defs/id"},
              "credential_secret_id": {"type": "string", "minLength": 1, "maxLength": 512},
              "channel_id": {"type": "string", "pattern": "^C[A-Z0-9]+$"},
              "high_priority_usergroup_id": {"type": "string", "pattern": "^S[A-Z0-9]+$"}
            },
            "oneOf": [
              {"required": ["credential_secret_id"], "not": {"required": ["channel_id"]}},
              {"required": ["channel_id"], "not": {"required": ["credential_secret_id"]}}
            ]
          }
        },
        "rate_control": {
          "type": "object",
          "additionalProperties": false,
          "required": [
        "per_destination_min_interval_seconds",
        "slack_request_timeout_seconds",
        "max_retry_after_seconds",
            "max_network_attempts",
            "queue_max_receive_count",
            "worker_reserved_concurrency"
          ],
          "properties": {
        "per_destination_min_interval_seconds": {"type": "integer", "minimum": 1, "maximum": 60},
        "slack_request_timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 30},
            "max_retry_after_seconds": {"type": "integer", "minimum": 1, "maximum": 43100},
            "max_network_attempts": {"type": "integer", "minimum": 1, "maximum": 20},
            "queue_max_receive_count": {"type": "integer", "minimum": 10, "maximum": 1000},
            "worker_reserved_concurrency": {"type": "integer", "minimum": 1, "maximum": 20}
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "customer", "account_id", "regions", "route_id"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "customer": {"type": "string", "minLength": 1, "maxLength": 100, "pattern": ".*\\S.*"},
        "account_id": {"type": "string", "pattern": "^[0-9]{12}$"},
        "regions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/region"}
        },
        "route_id": {"$ref": "#/$defs/id"}
      }
    }
  }
}
